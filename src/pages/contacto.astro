---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacto — Best Growth Tools"
  description="¿Tienes una pregunta, sugerencia o propuesta? Contacta con el equipo de Best Growth Tools."
>
  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-sans text-3xl md:text-4xl font-bold text-text-primary mb-4">Contacto</h1>
      <p class="text-text-secondary text-lg mb-10">
        ¿Tienes una pregunta, quieres sugerirnos una herramienta para analizar o necesitas hablar con nosotros? Escríbenos y te responderemos lo antes posible.
      </p>

      <!-- Contact Form -->
      <form action="https://formsubmit.co/info@bestgrowthtools.com" method="POST" class="space-y-6">
        <!-- Honeypot anti-spam -->
        <input type="text" name="_honey" style="display:none">
        <!-- Disable captcha -->
        <input type="hidden" name="_captcha" value="false">
        <!-- Success redirect -->
        <input type="hidden" name="_next" value="https://bestgrowthtools.com/contacto-gracias">

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block text-sm font-medium text-text-primary mb-2">Nombre *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Tu nombre"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-text-primary placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-text-primary mb-2">Email *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="tu@email.com"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-text-primary placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors"
            />
          </div>
        </div>

        <div>
          <label for="subject" class="block text-sm font-medium text-text-primary mb-2">Motivo</label>
          <select
            id="subject"
            name="subject"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-text-primary focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors"
          >
            <option value="general">Consulta general</option>
            <option value="suggest-tool">Sugerir una herramienta para analizar</option>
            <option value="correction">Corrección o actualización de información</option>
            <option value="partnership">Propuesta de colaboración</option>
            <option value="other">Otro</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-text-primary mb-2">Mensaje *</label>
          <textarea
            id="message"
            name="message"
            required
            rows="6"
            placeholder="Escribe tu mensaje aquí..."
            class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-text-primary placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-accent/30 focus:border-accent transition-colors resize-y"
          ></textarea>
        </div>

        <div>
          <button type="submit" class="btn-primary w-full md:w-auto !px-8 !py-3">
            Enviar mensaje →
          </button>
        </div>

        <p class="text-text-muted text-xs">
          Al enviar este formulario, aceptas nuestra <a href="/privacidad" class="text-accent hover:underline">Política de Privacidad</a>. Tus datos se usarán exclusivamente para responder a tu consulta.
        </p>
      </form>

      <!-- Direct contact -->
      <div class="mt-16 pt-12 border-t border-gray-100">
        <h2 class="font-sans text-xl font-bold text-text-primary mb-6">Contacto directo</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="card-static p-6">
            <span class="text-2xl block mb-3">📧</span>
            <h3 class="font-sans font-semibold text-text-primary mb-1">Email</h3>
            <a href="mailto:info@bestgrowthtools.com" class="text-accent hover:underline text-sm">info@bestgrowthtools.com</a>
          </div>
          <div class="card-static p-6">
            <span class="text-2xl block mb-3">⏱️</span>
            <h3 class="font-sans font-semibold text-text-primary mb-1">Tiempo de respuesta</h3>
            <p class="text-text-secondary text-sm">Respondemos en 24-48 horas laborables</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
