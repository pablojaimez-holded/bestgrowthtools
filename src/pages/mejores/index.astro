---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categories } from '../../data/categories';

const tops = await getCollection('top5');

// Map category slugs to category data
const topsByCategory = tops.map(top => {
  const cat = categories.find(c => c.slug === top.data.category);
  return {
    ...top.data,
    categoryName: cat?.name || top.data.category,
    categoryIcon: cat?.icon || '📋',
  };
}).sort((a, b) => a.title.localeCompare(b.title));
---

<BaseLayout
  title="Mejores Herramientas SaaS 2026 — Rankings Top 5 por Categoría"
  description="Descubre las mejores herramientas SaaS en 2026. Rankings Top 5 en CRM, Email Marketing, E-commerce, Analytics, Productividad y más. Comparativas actualizadas."
>
  <section class="py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-1.5 bg-accent/10 text-accent rounded-full text-sm font-medium mb-4">
          🏆 Rankings actualizados 2026
        </span>
        <h1 class="text-4xl sm:text-5xl font-bold text-text-primary mb-4">
          Las Mejores Herramientas SaaS
        </h1>
        <p class="text-lg text-text-secondary max-w-2xl mx-auto">
          Rankings Top 5 en cada categoría. Analizamos funcionalidades, precios, facilidad de uso e integraciones para ayudarte a elegir.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {topsByCategory.map(top => (
          <a href={`/mejores/${top.slug}`} class="group bg-white rounded-2xl border border-cream-dark/50 p-6 hover:shadow-card-hover hover:border-accent/30 transition-all duration-300">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-2xl">{top.categoryIcon}</span>
              <h2 class="text-xl font-bold text-text-primary group-hover:text-accent transition-colors">{top.title}</h2>
            </div>
            <p class="text-text-secondary text-sm mb-4">
              Comparativa de las 5 mejores herramientas de {top.categoryName?.toLowerCase()} del mercado.
            </p>
            <span class="text-accent font-semibold text-sm flex items-center gap-1">
              Ver ranking →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
