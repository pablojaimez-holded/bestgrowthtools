---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { toolDomains } from '../data/domains';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object;
}

const { title, description, canonical, schema } = Astro.props;
const domainsJson = JSON.stringify(toolDomains);
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <SEOHead title={title} description={description} canonical={canonical} schema={schema} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script define:vars={{ domainsJson }}>
      // Replace inline /logos/*.svg with Clearbit logos (for markdown content)
      const domains = JSON.parse(domainsJson);
      document.querySelectorAll('img[src^="/logos/"]').forEach(img => {
        const slug = img.getAttribute('src').replace('/logos/', '').replace('.svg', '').replace('.png', '');
        const domain = domains[slug];
        if (domain) {
          const original = img.getAttribute('src');
          img.onerror = function() { this.onerror = null; this.src = original; };
          img.src = `https://logo.clearbit.com/${domain}?size=128`;
        }
      });
    </script>
  </body>
</html>
