---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  lastUpdated?: string;
}

const { title, description, lastUpdated } = Astro.props;
---

<BaseLayout title={`${title} — Best Growth Tools`} description={description}>
  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-sans text-3xl md:text-4xl font-bold text-text-primary mb-4">{title}</h1>
      {lastUpdated && (
        <p class="text-text-muted text-sm mb-8">Última actualización: {lastUpdated}</p>
      )}
      <div class="prose prose-lg max-w-none text-text-secondary leading-relaxed space-y-6">
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>
