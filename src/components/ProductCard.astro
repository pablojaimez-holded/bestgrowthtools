---
import RatingStars from './RatingStars.astro';
import LogoImg from './LogoImg.astro';

interface Props {
  name: string;
  slug: string;
  logo?: string;
  tagline: string;
  rating: number;
  pricing: string;
  category: string;
  pros?: string[];
  affiliateUrl?: string;
}

const { name, slug, logo, tagline, rating, pricing, category, pros = [], affiliateUrl } = Astro.props;
---

<article class="card p-6 flex flex-col gap-4">
  <div class="flex items-start gap-4">
    <!-- Logo -->
    <div class="w-14 h-14 rounded-2xl bg-cream flex items-center justify-center shrink-0 overflow-hidden">
      <LogoImg slug={slug} name={name} class="w-10 h-10 object-contain" />
    </div>

    <!-- Info -->
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <h3 class="font-sans font-bold text-lg text-text-primary truncate">{name}</h3>
        <span class="badge bg-cream text-text-muted text-xs">{category}</span>
      </div>
      <p class="text-text-secondary text-sm mb-2">{tagline}</p>
      <div class="flex items-center gap-3">
        <RatingStars rating={rating} size="sm" />
        <span class="text-sm font-mono font-medium text-accent">{pricing}</span>
      </div>
    </div>
  </div>

  <!-- Pros highlights -->
  {pros.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {pros.slice(0, 3).map(pro => (
        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-pro-bg text-pro-green text-xs font-medium">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          {pro}
        </span>
      ))}
    </div>
  )}

  <!-- Actions -->
  <div class="flex items-center gap-3 mt-auto pt-2">
    <a href={`/review/${slug}`} class="btn-outline text-sm flex-1 text-center">Ver review</a>
    {affiliateUrl && (
      <a href={affiliateUrl} target="_blank" rel="noopener sponsored" class="btn-primary text-sm flex-1 text-center">
        Probar gratis →
      </a>
    )}
  </div>
</article>
