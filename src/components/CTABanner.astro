---
interface Props {
  title: string;
  subtitle?: string;
  buttonText: string;
  buttonUrl: string;
  isAffiliate?: boolean;
}

const { title, subtitle, buttonText, buttonUrl, isAffiliate = false } = Astro.props;
---

<section class="my-16">
  <div class="relative overflow-hidden rounded-card bg-gradient-to-r from-accent via-violet to-accent p-12 text-center">
    <!-- Background glow -->
    <div class="absolute inset-0 bg-gradient-to-r from-accent/20 to-violet/20 blur-3xl"></div>

    <div class="relative z-10">
      <h2 class="font-sans text-3xl font-bold text-white mb-3">{title}</h2>
      {subtitle && <p class="text-white/80 text-lg mb-8 max-w-2xl mx-auto">{subtitle}</p>}
      <a
        href={buttonUrl}
        target={isAffiliate ? "_blank" : undefined}
        rel={isAffiliate ? "noopener sponsored" : undefined}
        class="inline-flex items-center justify-center px-8 py-4 rounded-full font-sans font-bold text-accent bg-white
               hover:bg-cream hover:shadow-lg hover:-translate-y-0.5
               transition-all duration-300 text-lg"
      >
        {buttonText}
      </a>
    </div>
  </div>
</section>
