---
import { toolDomains } from '../data/domains';

interface Props {
  slug: string;
  name: string;
  class?: string;
  width?: number;
  height?: number;
}

const { slug, name, class: className = "w-10 h-10 object-contain", width = 128, height = 128 } = Astro.props;

const domain = toolDomains[slug];
const clearbitUrl = domain ? `https://logo.clearbit.com/${domain}?size=${width > 64 ? 128 : 64}` : null;
const fallbackUrl = `/logos/${slug}.svg`;
---

{clearbitUrl ? (
  <img
    src={clearbitUrl}
    alt={`${name} logo`}
    class={className}
    width={width}
    height={height}
    loading="lazy"
    onerror={`this.onerror=null;this.src='${fallbackUrl}'`}
  />
) : (
  <img
    src={fallbackUrl}
    alt={`${name} logo`}
    class={className}
    width={width}
    height={height}
    loading="lazy"
  />
)}
