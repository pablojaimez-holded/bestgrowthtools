---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex items-center gap-2 text-sm text-text-muted flex-wrap">
    <li>
      <a href="/" class="hover:text-accent transition-colors">Inicio</a>
    </li>
    {items.map((item, i) => (
      <li class="flex items-center gap-2">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        {item.href && i < items.length - 1 ? (
          <a href={item.href} class="hover:text-accent transition-colors">{item.label}</a>
        ) : (
          <span class="text-text-primary font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://bestgrowthtools.com/" },
    ...items.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 2,
      "name": item.label,
      ...(item.href ? { "item": `https://bestgrowthtools.com${item.href}` } : {})
    }))
  ]
})} />
