---
import { categories } from '../data/categories';
---

<header class="sticky top-0 z-50 bg-cream/80 backdrop-blur-lg border-b border-cream-dark/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent to-violet flex items-center justify-center">
          <span class="text-white font-bold text-sm">BG</span>
        </div>
        <span class="font-sans font-bold text-xl text-text-primary">Best<span class="gradient-text">Growth</span>Tools</span>
      </a>

      <!-- Nav -->
      <nav class="hidden md:flex items-center gap-8">
        <div class="relative group">
          <button class="text-text-secondary hover:text-text-primary font-medium transition-colors flex items-center gap-1">
            Categorías
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-2 w-64 bg-white rounded-card shadow-card-hover opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 p-2">
            {categories.map(cat => (
              <a href={`/categoria/${cat.slug}`} class="flex items-center gap-3 px-4 py-2.5 rounded-xl hover:bg-cream transition-colors">
                <span class="text-lg">{cat.icon}</span>
                <span class="font-medium text-text-primary">{cat.name}</span>
              </a>
            ))}
          </div>
        </div>
        <a href="/mejores/crm" class="text-text-secondary hover:text-text-primary font-medium transition-colors">Top 5</a>
        <a href="/comparar/hubspot-vs-pipedrive" class="text-text-secondary hover:text-text-primary font-medium transition-colors">Comparar</a>
        <a href="/sobre-nosotros" class="text-text-secondary hover:text-text-primary font-medium transition-colors">Sobre nosotros</a>
      </nav>

      <!-- Search + CTA -->
      <div class="flex items-center gap-4">
        <button id="search-toggle" class="p-2 text-text-muted hover:text-text-primary transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
        <a href="/mejores/crm" class="hidden sm:inline-flex btn-primary text-sm !px-4 !py-2">
          Encuentra tu herramienta
        </a>
      </div>
    </div>
  </div>
</header>
